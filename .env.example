# PostgreSQL — Docker Compose maps Postgres to host port 5433
DATABASE_URL="postgresql://lms:lms_secret@localhost:5433/lms"
# Same as DATABASE_URL locally. On Neon: use the **direct** connection string (Dashboard → Connection details → “direct”).
DIRECT_DATABASE_URL="postgresql://lms:lms_secret@localhost:5433/lms"

# --- Hosted Postgres (Neon / Supabase / Railway) ---
# Example Neon:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# If Neon gives you a separate “pooled” URL for serverless, put pooled in DATABASE_URL and **direct** (non-pooler) in DIRECT_DATABASE_URL.

# Auth.js — `openssl rand -base64 32` (or any long random string)
AUTH_SECRET=""

# Site URL (used by Auth.js)
NEXTAUTH_URL="http://localhost:3000"

# Public URL for the app (used in metadata)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Ollama (local)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL_COURSE="gemma:7b"
OLLAMA_MODEL_FAST="gemma:7b"
# Higher value reduces truncated JSON on long drafts (passed as Ollama num_predict when generating courses with JSON mode)
OLLAMA_NUM_PREDICT_COURSE="8192"
